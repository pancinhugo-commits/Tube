(
    // Bloc 1 : Quart de tube (0-90 degrés)
    hex (0 1 9 8 4 5 13 12) (radialCells circumferentialCells/4 axialCells) simpleGrading (1 1 1)

    // Bloc 2 : Quart de tube (90-180 degrés)
    hex (1 2 10 9 5 6 14 13) (radialCells circumferentialCells/4 axialCells) simpleGrading (1 1 1)

    // Bloc 3 : Quart de tube (180-270 degrés)
    hex (2 3 11 10 6 7 15 14) (radialCells circumferentialCells/4 axialCells) simpleGrading (1 1 1)

    // Bloc 4 : Quart de tube (270-360 degrés)
    hex (3 0 8 11 7 4 12 15) (radialCells circumferentialCells/4 axialCells) simpleGrading (1 1 1)
);

