FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      blockMeshDict;
}

// -------------------------------------------------------------------
// Configuration du maillage
// -------------------------------------------------------------------

// Nombre de cellules dans chaque direction
radialCells           10;    // Entre R_inner et R_outer
circumferentialCells  8;     // Nombre de cellules par quart de cercle
axialCells            20;    // Le long de la longueur

// Rayons et longueur
R_inner               0.1;   // Rayon intérieur [m]
R_outer               0.2;   // Rayon extérieur [m]
L                     1.0;   // Longueur du tube [m]

// Pré-calcul des valeurs négatives
R_inner_neg           #calc "-$R_inner";
R_outer_neg           #calc "-$R_outer";

// -------------------------------------------------------------------
// Définition des points (vertices) - 16 points pour 4 quarts
// -------------------------------------------------------------------
vertices
(
    // Points intérieurs (cercle intérieur) à z = 0
    ($R_inner 0 0)          // 0: 0°
    (0 $R_inner 0)          // 1: 90°
    ($R_inner_neg 0 0)      // 2: 180°
    (0 $R_inner_neg 0)      // 3: 270°

    // Points extérieurs (cercle extérieur) à z = 0
    ($R_outer 0 0)          // 4: 0°
    (0 $R_outer 0)          // 5: 90°
    ($R_outer_neg 0 0)      // 6: 180°
    (0 $R_outer_neg 0)      // 7: 270°

    // Points intérieurs à z = L (extrémité)
    ($R_inner 0 $L)         // 8: 0°
    (0 $R_inner $L)         // 9: 90°
    ($R_inner_neg 0 $L)     // 10: 180°
    (0 $R_inner_neg $L)     // 11: 270°

    // Points extérieurs à z = L (extrémité)
    ($R_outer 0 $L)         // 12: 0°
    (0 $R_outer $L)         // 13: 90°
    ($R_outer_neg 0 $L)     // 14: 180°
    (0 $R_outer_neg $L)     // 15: 270°
);

// -------------------------------------------------------------------
// Définition des blocs (hexahédriques) - 4 blocs pour les 4 quarts
// -------------------------------------------------------------------
blocks
(
    // Bloc 1 : Quart de tube (0°-90°)
    hex (0 1 9 8 4 5 13 12) (radialCells circumferentialCells axialCells) simpleGrading (1 1 1)

    // Bloc 2 : Quart de tube (90°-180°)
    hex (1 2 10 9 5 6 14 13) (radialCells circumferentialCells axialCells) simpleGrading (1 1 1)

    // Bloc 3 : Quart de tube (180°-270°)
    hex (2 3 11 10 6 7 15 14) (radialCells circumferentialCells axialCells) simpleGrading (1 1 1)

    // Bloc 4 : Quart de tube (270°-360°)
    hex (3 0 8 11 7 4 12 15) (radialCells circumferentialCells axialCells) simpleGrading (1 1 1)
);

// -------------------------------------------------------------------
// Définition des arcs dans edges
// -------------------------------------------------------------------
edges
(
    // Arcs pour le cercle intérieur à z = 0
    arc 0 1 (0 0 0)         // Arc de 0° à 90° (cercle intérieur, z=0)
    arc 1 2 (0 0 0)         // Arc de 90° à 180° (cercle intérieur, z=0)
    arc 2 3 (0 0 0)         // Arc de 180° à 270° (cercle intérieur, z=0)
    arc 3 0 (0 0 0)         // Arc de 270° à 360° (cercle intérieur, z=0)

    // Arcs pour le cercle extérieur à z = 0
    arc 4 5 (0 0 0)         // Arc de 0° à 90° (cercle extérieur, z=0)
    arc 5 6 (0 0 0)         // Arc de 90° à 180° (cercle extérieur, z=0)
    arc 6 7 (0 0 0)         // Arc de 180° à 270° (cercle extérieur, z=0)
    arc 7 4 (0 0 0)         // Arc de 270° à 360° (cercle extérieur, z=0)

    // Arcs pour le cercle intérieur à z = L
    arc 8 9 (0 0 $L)        // Arc de 0° à 90° (cercle intérieur, z=L)
    arc 9 10 (0 0 $L)       // Arc de 90° à 180° (cercle intérieur, z=L)
    arc 10 11 (0 0 $L)      // Arc de 180° à 270° (cercle intérieur, z=L)
    arc 11 8 (0 0 $L)       // Arc de 270° à 360° (cercle intérieur, z=L)

    // Arcs pour le cercle extérieur à z = L
    arc 12 13 (0 0 $L)      // Arc de 0° à 90° (cercle extérieur, z=L)
    arc 13 14 (0 0 $L)      // Arc de 90° à 180° (cercle extérieur, z=L)
    arc 14 15 (0 0 $L)      // Arc de 180° à 270° (cercle extérieur, z=L)
    arc 15 12 (0 0 $L)      // Arc de 270° à 360° (cercle extérieur, z=L)
);

// -------------------------------------------------------------------
// Définition des patches (frontières)
// -------------------------------------------------------------------
boundary
(
    // Paroi intérieure du tube
    innerWall
    {
        type    patch;
        faces
        (
            (0 1 9 8)
            (1 2 10 9)
            (2 3 11 10)
            (3 0 8 11)
        );
    }

    // Paroi extérieure du tube
    outerWall
    {
        type    patch;
        faces
        (
            (4 5 13 12)
            (5 6 14 13)
            (6 7 15 14)
            (7 4 12 15)
        );
    }

    // Entrée du tube (z = 0)
    inlet
    {
        type    patch;
        faces
        (
            (0 4 5 1)
            (1 5 6 2)
            (2 6 7 3)
            (3 7 4 0)
        );
    }

    // Sortie du tube (z = L)
    outlet
    {
        type    patch;
        faces
        (
            (8 12 13 9)
            (9 13 14 10)
            (10 14 15 11)
            (11 15 12 8)
        );
    }

    // Frontière par défaut
    defaultFaces
    {
        type    empty;
        faces   ();
    }
);

// -------------------------------------------------------------------
// Merge des points pour éviter les doublons
// -------------------------------------------------------------------
mergePatchPairs
(
);
