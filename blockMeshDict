FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale 0.01;

// radius of injector
r1 10;
// radius of first refinement zone
r2 11;
// Lenght of domain
L 80;

l1 #calc "($r1*cos(45*3.14/180))";
l2 #calc "($r2*cos(45*3.14/180))";
l1m #calc "-$l1";
l2m #calc "-$l2";
r1m #calc "-$r1";
r2m #calc "-$r2";


// number of vortices in x and y directions
nxy 10;
// number of vorticies in z direction
nz 10;

vertices
(
    ($l1 $l1 0)	        // vertex 0
    ($l1m $l1 0)	// vertex 1
    ($l1m $l1m 0)	// vertex 2
    ($l1 $l1m 0)	// vertex 3
    ($l2 $l2 0)	        // vertex 4
    ($l2m $l2 0)	// vertex 5
    ($l2m $l2m 0)	// vertex 6
    ($l2 $l2m 0)	// vertex 7
    ($l1 $l1 $L)	// vertex 8
    ($l1m $l1 $L)	// vertex 9
    ($l1m $l1m $L)      // vertex 10
    ($l1 $l1m $L)	// vertex 11
    ($l2 $l2 $L)	// vertex 12
    ($l2m $l2 $L)	// vertex 13
    ($l2m $l2m $L)      // vertex 14
    ($l2 $l2m $L)	// vertex 15
    
);

blocks
(
     hex (0 4 5 1 8 12 13 9) ($nxy $nxy $nz) simpleGrading (1 1 1)	// block 1
    hex (1 5 6 2 9 13 14 10) ($nxy $nxy $nz) simpleGrading (1 1 1)	// block 2
    hex (2 6 7 3 10 14 15 11) ($nxy $nxy $nz) simpleGrading (1 1 1)	// block 3
    hex (7 4 0 3 15 12 8 11) ($nxy $nxy $nz) simpleGrading (1 1 1)	// block 4
);

edges
( 

    arc 4 5 (0 $r2 0)		// edge 1
    arc 5 6 ($r2m 0 0)		// edge 2
    arc 6 7 (0 $r2m 0)		// edge 3
    arc 7 4 ($r2 0 0)		// edge 4
    arc 0 1 (0 $r1 0)	        // edge 5
    arc 1 2 ($r1m 0 0)	        // edge 6
    arc 2 3 (0 $r1m 0)	        // edge 7
    arc 3 0 ($r1 0 0)	        // edge 8


    arc 12 13 (0 $r2 $L)	// edge 9
    arc 13 14 ($r2m 0 $L)	// edge 10
    arc 14 15 (0 $r2m $L)	// edge 11
    arc 15 12 ($r2 0 $L)	// edge 12
    arc 8 9 (0 $r1 $L)	        // edge 13
    arc 9 10 ($r1m 0 $L)	// edge 14
    arc 10 11 (0 $r1m $L)	// edge 15
    arc 11 8 ($r1 0 $L)	        // edge 16 
    
);

boundary
( 

);

mergePatchPairs
(
);

