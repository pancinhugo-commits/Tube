// -------------------------------------------------------------------
// Configuration du maillage
// -------------------------------------------------------------------

// Nombre de cellules dans chaque direction
radialCells           10;    // Entre R_inner et R_outer
circumferentialCells  20;    // Autour du tube
axialCells            20;    // Le long de la longueur

// Rayons et longueur
R_inner               0.1;   // Rayon intérieur [m]
R_outer               0.2;   // Rayon extérieur [m]
L                     1.0;   // Longueur du tube [m]

// -------------------------------------------------------------------
// Déclaration des expressions #calc pour les coordonnées
// -------------------------------------------------------------------
xInner0   #calc "$R_inner*::cos(0)";
yInner0   #calc "$R_inner*::sin(0)";
xInner90  #calc "$R_inner*::cos(90)";
yInner90  #calc "$R_inner*::sin(90)";
xInner180 #calc "$R_inner*::cos(180)";
yInner180 #calc "$R_inner*::sin(180)";
xInner270 #calc "$R_inner*::cos(270)";
yInner270 #calc "$R_inner*::sin(270)";

xOuter0   #calc "$R_outer*::cos(0)";
yOuter0   #calc "$R_outer*::sin(0)";
xOuter90  #calc "$R_outer*::cos(90)";
yOuter90  #calc "$R_outer*::sin(90)";
xOuter180 #calc "$R_outer*::cos(180)";
yOuter180 #calc "$R_outer*::sin(180)";
xOuter270 #calc "$R_outer*::cos(270)";
yOuter270 #calc "$R_outer*::sin(270)";

// -------------------------------------------------------------------
// Définition des points (vertices)
// -------------------------------------------------------------------
vertices
(
    // Points intérieurs (cercle intérieur) à z = 0
    ($xInner0 $yInner0 0)        // 0
    ($xInner90 $yInner90 0)      // 1
    ($xInner180 $yInner180 0)    // 2
    ($xInner270 $yInner270 0)    // 3

    // Points extérieurs (cercle extérieur) à z = 0
    ($xOuter0 $yOuter0 0)        // 4
    ($xOuter90 $yOuter90 0)      // 5
    ($xOuter180 $yOuter180 0)    // 6
    ($xOuter270 $yOuter270 0)    // 7

    // Points intérieurs à z = L (extrémité)
    ($xInner0 $yInner0 $L)        // 8
    ($xInner90 $yInner90 $L)      // 9
    ($xInner180 $yInner180 $L)    // 10
    ($xInner270 $yInner270 $L)    // 11

    // Points extérieurs à z = L (extrémité)
    ($xOuter0 $yOuter0 $L)        // 12
    ($xOuter90 $yOuter90 $L)      // 13
    ($xOuter180 $yOuter180 $L)    // 14
    ($xOuter270 $yOuter270 $L)    // 15
);

// -------------------------------------------------------------------
